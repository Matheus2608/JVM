# Arquivos e Diretórios de Entrada
INPUT                  = jvm/ jvm/common jvm/leitor jvm/parser jvm/exibidor jvm/loader jvm/runtime jvm/heap jvm/interpreter README.md mainpage.dox
FILE_PATTERNS          = *.cpp *.hpp *.md *.dox
